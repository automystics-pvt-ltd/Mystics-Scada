# Copy this file to .env.gateway and fill in the values below.

# Plaintext token from Org Settings → Gateways → Generate Token (shown once).
GATEWAY_TOKEN=

# Base URL of the cloud API, including the /api path prefix.
API_URL=https://your-project.replit.app/api

# Optional overrides — defaults shown.
# BUFFER_DB_PATH=./data/readings.db
# BUFFER_MAX_ROWS=10000
# BUFFER_FLUSH_BATCH=200
# HEARTBEAT_INTERVAL_MS=30000
# DEVICE_REFRESH_MS=300000
